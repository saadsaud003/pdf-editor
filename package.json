{
  "name": "pdf-editor",
  "version": "1.0.0",
  "description": "محرر PDF - تطبيق ويب متقدم لتحرير ملفات PDF",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server . -p 8091 -o",
    "build": "node -e \"const fs=require('fs');const p=require('path');function c(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>{const sp=p.join(s,f),dp=p.join(d,f);if(fs.statSync(sp).isDirectory()){if(!['node_modules','android','ios','www','.git','.github','.claude'].includes(f))c(sp,dp)}else fs.copyFileSync(sp,dp)});} c('.','www');\"",
    "cap:init": "npx cap init pdf-editor com.pdfeditor.app --web-dir www",
    "cap:add": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open": "npx cap open android",
    "cap:build": "cd android && ./gradlew assembleDebug",
    "cap:build-release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/core": "^5.7.0",
    "@capacitor/android": "^5.7.0",
    "@capacitor/filesystem": "^5.2.0",
    "@capacitor/share": "^5.0.7",
    "@capacitor/status-bar": "^5.0.7",
    "@capacitor/splash-screen": "^5.0.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0"
  },
  "keywords": ["pdf", "editor", "arabic", "pwa"],
  "license": "MIT"
}
